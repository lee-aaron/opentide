# Copy to .env and fill in your values
# Required
OPENTIDE_ADMIN_SECRET=change-me-to-a-random-secret

# LLM Providers (at least one required, multiple supported for routing)
# Option 1: Anthropic
ANTHROPIC_API_KEY=
# Option 2: OpenAI
OPENAI_API_KEY=
# Option 3: DO Gradient (get key from DO Control Panel → Serverless Inference → Model Access Keys)
MODEL_ACCESS_KEY=

# Default provider (auto-detected if not set). Values: anthropic, openai, gradient
# OPENTIDE_DEFAULT_PROVIDER=

# Messaging adapter (at least one required in non-demo mode)
DISCORD_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Skill configuration (optional)
# GitHub skill - for private repos and higher rate limits
GITHUB_TOKEN=
# Image generation skill - uses OPENAI_API_KEY above
# Web search skill
BRAVE_API_KEY=
