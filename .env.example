# Copy to .env and fill in your values
# Required
OPENTIDE_ADMIN_SECRET=change-me-to-a-random-secret

# LLM Provider (at least one required)
# Option 1: Anthropic direct
ANTHROPIC_API_KEY=
# Option 2: OpenAI direct
OPENAI_API_KEY=
# Option 3: DO Gradient (get key from DO Control Panel → Serverless Inference → Model Access Keys)
MODEL_ACCESS_KEY=

# Messaging adapter (at least one required in non-demo mode)
DISCORD_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
